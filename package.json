{
  "name": "com.aegis.app",
  "displayName": "Aegis",
  "version": "1.0.0",
  "description": "Aegis AI – Android WebView wrapper for https://qualie--aegis-weather.asia-southeast1.hosted.app/listen",
  "main": "index.js",
  "scripts": {
    "prepare": "cordova prepare android",
    "build": "cordova prepare android && cd platforms/android && gradlew assembleDebug",
    "build:release": "cordova prepare android && cd platforms/android && gradlew assembleRelease",
    "run": "cordova run android",
    "clean": "cd platforms/android && gradlew clean"
  },
  "keywords": [
    "ecosystem:cordova",
    "cordova-android"
  ],
  "author": "Frank Mathew Sajan",
  "license": "Apache-2.0",
  "devDependencies": {
    "cordova-android": "^14.0.1",
    "cordova-plugin-android-permissions": "^1.1.5",
    "cordova-plugin-inappbrowser": "^6.0.0",
    "cordova.plugins.diagnostic": "github:dpa99c/cordova-diagnostic-plugin"
  },
  "cordova": {
    "platforms": [
      "android"
    ],
    "plugins": {
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-android-permissions": {},
      "cordova.plugins.diagnostic": {
        "ANDROIDX_VERSION": "1.0.0",
        "ANDROIDX_APPCOMPAT_VERSION": "1.3.1"
      }
    }
  }
}
