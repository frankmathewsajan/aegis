{
  "name": "com.aegis.app",
  "displayName": "Aegis",
  "version": "1.0.0",
  "description": "Aegis AI – Android WebView wrapper for https://qualie--aegis-weather.asia-southeast1.hosted.app/listen",
  "main": "index.js",
  "scripts": {
    "prepare": "cordova prepare android",
    "build": "cordova build android --debug --buildConfig build.json",
    "build:release": "cordova build android --release --buildConfig build.json",
    "run": "cordova run android",
    "clean": "cd platforms/android && gradlew clean",
    "reset": "adb shell pm clear com.aegis.app",
    "generate-debug-key": "mkdir -p keystore && keytool -genkey -v -keystore keystore/debug.keystore -alias androiddebugkey -keyalg RSA -keysize 2048 -validity 10000 -storepass android -keypass android -dname \"CN=Android Debug,O=Android,C=US\""
  },
  "keywords": [
    "ecosystem:cordova",
    "cordova-android"
  ],
  "author": "Frank Mathew Sajan",
  "license": "Apache-2.0",
  "devDependencies": {
    "cordova-android": "^14.0.1",
    "cordova-plugin-android-permissions": "^1.1.5",
    "cordova-plugin-inappbrowser": "^6.0.0",
    "cordova.plugins.diagnostic": "github:dpa99c/cordova-diagnostic-plugin"
  },
  "cordova": {
    "platforms": [
      "android"
    ],
    "plugins": {
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-android-permissions": {},
      "cordova.plugins.diagnostic": {
        "ANDROIDX_VERSION": "1.0.0",
        "ANDROIDX_APPCOMPAT_VERSION": "1.3.1"
      }
    }
  },
  "dependencies": {
    "cordova": "^13.0.0"
  }
}
